{
  "commit-msg": {
    "commands": {
      "commitlint": {
        "run": "bunx commitlint --config .config/commitlint.config.mjs --edit {1}"
      }
    }
  },
  "pre-commit": {
    "commands": {
      "lint": {
        "run": "mise exec -- just lint"
      },
      "test": {
        "run": "mise exec -- just test"
      }
    }
  },
  "pre-push": {
    "commands": {
      "coverage": {
        "run": "mise exec -- just coverage"
      }
    }
  }
}
