{
  "commit-msg": {
    "commands": {
      "commitlint": {
        "run": "bunx commitlint --config .config/commitlint.config.mjs --edit {1}"
      }
    }
  },
  "pre-commit": {
    "commands": {
      "lint": {
        "run": "just lint"
      },
      "test": {
        "run": "just test"
      }
    }
  },
  "pre-push": {
    "commands": {
      "coverage-check": {
        "run": "just coverage-check"
      }
    }
  }
}
